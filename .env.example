# ──────────────────────────────────────────────────────────────────
# Postgres
# ──────────────────────────────────────────────────────────────────
# `vercel env pull .env.local` will populate one of these depending on
# which integration you connected:
#
#   • Neon (new Vercel marketplace storage) sets DATABASE_URL[_UNPOOLED]
#   • Old @vercel/postgres sets POSTGRES_URL[_NON_POOLING]
#
# Either works — lib/load-env.ts maps DATABASE_URL → POSTGRES_URL.

POSTGRES_URL=
POSTGRES_URL_NON_POOLING=

# These are the keys the Neon integration uses; copy them too if present.
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# ──────────────────────────────────────────────────────────────────
# Vercel Blob (image uploads)
# ──────────────────────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=

# ──────────────────────────────────────────────────────────────────
# Auth (admin dashboard)
# ──────────────────────────────────────────────────────────────────
# Generate AUTH_SECRET with:  openssl rand -base64 32
AUTH_SECRET=
ADMIN_EMAIL=

# ──────────────────────────────────────────────────────────────────
# Public site URL (used in sitemap, OG tags, JSON-LD)
# ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://vandanaskindiary.com
